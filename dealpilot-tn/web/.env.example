# Example env for Closing Jet web app (copy to .env.local and fill in).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

OPENAI_API_KEY=
REVA_ASSISTANT_ID_TN=

# POST /api/inbound/email — Make.com webhook; use header Authorization: Bearer <value>
INBOUND_WEBHOOK_SECRET=

# Optional; inbound email route uses this first, then REVA_ASSISTANT_ID_TN
OPENAI_ASSISTANT_ID=

# GoHighLevel (location API key) — used by inbound email auto-reply via conversations/messages
GHL_API_KEY=
# Optional; include if your GHL project requires location on email sends
GHL_LOCATION_ID=
